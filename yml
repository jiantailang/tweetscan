name: Tweet Monitor

on:
  schedule:
    # 2日に1回、日本時間の午前9時（UTC 0:00）に実行
    - cron: '0 0 */2 * *'
  workflow_dispatch: # 手動で実行できるボタンを有効化

# 実行した結果のファイルをリポジトリへ書き込むための権限
permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'
      - name: Install dependencies
        run: pip install feedparser
      - name: Run Script
        run: python main.py
      - name: Commit and Push
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add results.md
          git commit -m "Update filtered tweets" || exit 0
          git push
